    {
      "id": "blur-fade-in",
      "name": "Blur Fade In",
      "summary": "A conservative native preset for quick entrance motion scaffolding.",
      "category": "entrance",
      "status": "beta",
      "tags": ["native", "hero", "reveal"],
      "compatibleTargets": ["frame", "image", "text", "component-instance", "svg"],
      "selectionPolicy": "single",
      "implementationType": "native",
      "applyStrategy": "set-attributes",
      "previewUrl": "https://images.unsplash.com/photo-1515879218367-8466d910aaa4?auto=format&fit=crop&w=800&q=80",
      "previewAlt": "Blur Fade In preview",
      "defaultParams": {
        "opacity": 0.15,
        "blur": 8,
        "duration": 0.45
      },
      "controls": [
        {
          "id": "opacity",
          "label": "Start Opacity",
          "type": "number",
          "description": "Initial opacity before the user tunes the entrance effect.",
          "defaultValue": 0.15,
          "min": 0,
          "max": 1,
          "step": 0.05
        },
        {
          "id": "duration",
          "label": "Duration",
          "type": "number",
          "description": "Reference timing for later tuning in Framer.",
          "defaultValue": 0.45,
          "min": 0.1,
          "max": 2,
          "step": 0.05
        }
      ],
      "nativePatch": {
        "attributes": {
          "opacity": 0.15
        },
        "notes": [
          "This starter recipe only seeds conservative attributes.",
          "Scroll transforms and easing still need fuller implementation in the plugin."
        ]
      },
      "authoringNotes": [
        "Use this as a safe native template, not as a complete timeline engine."
      ]
    },
