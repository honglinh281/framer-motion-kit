{
  "libraryProject": {
    "name": "MotionKit VFX Library",
    "workspaceUrl": "https://framer.com/projects/[workspace-id]",
    "notes": "Publish Smart Components and Code Components here, then copy module URLs into the effect catalog."
  },
  "components": {
    "pixel-scroll": {
      "implementationType": "code-component",
      "moduleUrl": "https://framer.com/m/PixelScroll-[version].js@[build]",
      "insertMode": "instance",
      "version": "2026.04.13"
    },
    "parallax-depth": {
      "implementationType": "smart-component",
      "moduleUrl": "https://framer.com/m/ParallaxDepth-[version].js@[build]",
      "insertMode": "detached",
      "version": "2026.04.13"
    }
  }
}

